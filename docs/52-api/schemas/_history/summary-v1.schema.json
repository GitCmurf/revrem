{
  "$id": "https://github.com/GitCmurf/revrem/schemas/summary/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "artifact_dir": {
      "type": "string"
    },
    "artifact_paths": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        ]
      },
      "type": "object"
    },
    "base": {
      "type": "string"
    },
    "cli_version": {
      "minLength": 1,
      "type": "string"
    },
    "command_line": {
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "duration_seconds": {
      "description": "Elapsed wall-clock seconds for completed runs; null is reserved for externally supplied or partially reconstructed legacy summaries where elapsed time was unavailable.",
      "type": [
        "number",
        "null"
      ]
    },
    "finished_at": {
      "format": "date-time",
      "type": "string"
    },
    "final_status": {
      "enum": [
        "clear",
        "findings",
        "unknown",
        "error"
      ]
    },
    "external_review_coverage": {
      "additionalProperties": true,
      "properties": {
        "external_review_input_chars": {
          "type": [
            "integer",
            "null"
          ]
        },
        "external_review_truncation_policy": {
          "enum": [
            "warn",
            "fail",
            null
          ]
        },
        "prompt_chars": {
          "type": [
            "integer",
            "null"
          ]
        },
        "prompt_delivery": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt_truncated": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "review_context_chars": {
          "type": [
            "integer",
            "null"
          ]
        },
        "review_context_supplied_in_full": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "harness": {
      "type": "string"
    },
    "harness_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "invocation": {
      "additionalProperties": true,
      "properties": {
        "argv": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "command_line": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "cwd": {
          "type": "string"
        },
        "environment": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "schema_version": {
          "enum": [
            "1.0"
          ]
        }
      },
      "type": "object"
    },
    "iterations": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "type": "array"
    },
    "max_iterations": {
      "minimum": 1,
      "type": "integer"
    },
    "phases": {
      "additionalProperties": {
        "additionalProperties": {
          "type": [
            "integer",
            "number",
            "string",
            "boolean",
            "null"
          ]
        },
        "type": "object"
      },
      "type": "object"
    },
    "phase_failures": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "diagnostic_artifact": {
            "type": "string"
          },
          "failure": {
            "additionalProperties": true,
            "type": "object"
          },
          "iteration": {
            "type": "string"
          },
          "phase": {
            "type": "string"
          },
          "redirected_retry_command": {
            "type": "string"
          }
        },
        "required": [
          "phase",
          "iteration"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "phase_observations": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "diagnostic_artifact": {
            "type": "string"
          },
          "iteration": {
            "type": "string"
          },
          "observed": {
            "additionalProperties": true,
            "type": "object"
          },
          "phase": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "requested": {
            "additionalProperties": true,
            "type": "object"
          },
          "warnings": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "phase",
          "iteration",
          "provider"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "profile": {
      "type": [
        "string",
        "null"
      ]
    },
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "enum": [
        "1.0",
        "1.1"
      ]
    },
    "started_at": {
      "format": "date-time",
      "type": "string"
    },
    "stopped_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "tokens": {
      "additionalProperties": {
        "type": [
          "integer",
          "number",
          "null"
        ]
      },
      "type": [
        "object",
        "null"
      ]
    },
    "triage_diagnostics": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "artifact": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "usd": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "schema_version",
    "cli_version",
    "harness",
    "harness_version",
    "profile",
    "command_line",
    "run_id",
    "started_at",
    "finished_at",
    "duration_seconds",
    "base",
    "max_iterations",
    "artifact_dir",
    "iterations",
    "final_status",
    "stopped_reason",
    "phases",
    "artifact_paths",
    "tokens",
    "usd"
  ],
  "title": "RevRem summary v1",
  "type": "object"
}
