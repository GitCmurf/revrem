# Example environment file for local experimentation.
# Copy to .env only if a local workflow needs it. Never commit real secrets.

# Optional fallback contact used in public SECURITY.md examples.
REVREM_SECURITY_CONTACT=security@example.invalid

# Optional local stable install override used by scripts/promote-stable.
REVREM_STABLE_HOME=/tmp/revrem-example-stable
REVREM_BIN_DIR=/tmp/revrem-example-bin
