#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
PYTHON=${PYTHON:-python3}

cd "$REPO_ROOT"

python_supports_requires_python() {
  "$1" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)'
}

if [ -x ./.venv/bin/python ] && ! python_supports_requires_python ./.venv/bin/python; then
  rm -rf ./.venv
fi

if [ ! -x ./.venv/bin/python ]; then
  "$PYTHON" -m venv .venv
fi

if ! python_supports_requires_python ./.venv/bin/python; then
  printf '%s\n' "ERROR: ./.venv/bin/python must be Python 3.11 or newer to install development tooling." >&2
  exit 1
fi

if ./.venv/bin/python -m pip install -e ".[dev]"; then
  printf '%s\n' "Development install ready: $REPO_ROOT/.venv/bin/code-review-loop"
  exit 0
fi

cat > ./.venv/bin/code-review-loop <<EOF
#!/usr/bin/env sh
PYTHONPATH="$REPO_ROOT/src\${PYTHONPATH:+:\$PYTHONPATH}" exec "$REPO_ROOT/.venv/bin/python" -m code_review_loop "\$@"
EOF
cat > ./.venv/bin/revrem <<EOF
#!/usr/bin/env sh
PYTHONPATH="$REPO_ROOT/src\${PYTHONPATH:+:\$PYTHONPATH}" exec "$REPO_ROOT/.venv/bin/python" -m code_review_loop "\$@"
EOF
chmod +x ./.venv/bin/code-review-loop ./.venv/bin/revrem

printf '%s\n' 'WARNING: editable pip install failed; wrote source-tree launchers instead.' >&2
printf '%s\n' "Development launchers ready: $REPO_ROOT/.venv/bin/code-review-loop"
